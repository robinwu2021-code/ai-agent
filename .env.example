# ══════════════════════════════════════════════════════════
# AI Agent 环境配置
# 复制为 .env 并填写实际值
# ══════════════════════════════════════════════════════════

# ── LLM 提供商选择 ────────────────────────────────────────
# 可选值: anthropic | openai | azure | deepseek | groq | ollama | custom
LLM_PROVIDER=anthropic

# ── API Key ───────────────────────────────────────────────
# 通用 Key 字段（优先级最高）
# LLM_API_KEY=

# 提供商专用字段（当 LLM_API_KEY 未设置时自动读取）
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# AZURE_OPENAI_API_KEY=...

# ── API 端点 ──────────────────────────────────────────────
# 留空表示使用该提供商的默认端点
# LLM_BASE_URL=

# OpenAI 兼容接口示例：
# LLM_BASE_URL=https://api.deepseek.com/v1        # DeepSeek
# LLM_BASE_URL=https://api.groq.com/openai/v1     # Groq
# LLM_BASE_URL=http://localhost:11434/v1           # Ollama（本地）
# LLM_BASE_URL=https://your-resource.openai.azure.com  # Azure

# Azure 专用配置
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=my-gpt4o-deployment

# ── 模型选择 ──────────────────────────────────────────────
# 留空则使用各提供商的默认模型：
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4o
#   deepseek  → deepseek-chat
#   groq      → llama-3.3-70b-versatile
#   ollama    → llama3.2

# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MODEL=gpt-4o
# LLM_MODEL=deepseek-chat
# LLM_MODEL=qwen2.5:72b                  # Ollama 自定义模型

# Embedding 模型（留空则使用提供商默认，Anthropic 回退到哈希向量）
# LLM_EMBEDDING_MODEL=text-embedding-3-small   # OpenAI / Azure
#
# ⚠️  使用 Ollama 时必须指定本地 embedding 模型，否则退化为哈希向量（BM25 仍可用）：
#     1. 拉取模型：  ollama pull nomic-embed-text
#     2. 设置变量：  LLM_EMBEDDING_MODEL=nomic-embed-text
#
# 常用 Ollama embedding 模型：
#   nomic-embed-text      768 维，中英文表现均衡（推荐）
#   mxbai-embed-large     1024 维，精度较高
#   all-minilm            384 维，速度快，占用低
# LLM_EMBEDDING_MODEL=nomic-embed-text

# 摘要专用模型（可用便宜模型，留空同 LLM_MODEL）
# LLM_SUMMARIZE_MODEL=claude-haiku-4-5-20251001
# LLM_SUMMARIZE_MODEL=gpt-4o-mini

# ── 请求参数 ──────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SEC=120.0
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.7

# HTTP 代理（可选，例如 http://127.0.0.1:7890）
# LLM_HTTP_PROXY=

# ── 存储后端 ──────────────────────────────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379

USE_QDRANT=false
QDRANT_URL=http://localhost:6333

# ── 向量数据库后端（推荐在 llm.yaml vector_store 节配置，此处为兜底）──
#
# 优先级：llm.yaml vector_store 节 > 以下环境变量 > SQLite 兜底
#
# 选择后端（milvus 推荐生产使用）：
# VECTOR_BACKEND=milvus
#
# Milvus 连接参数：
# MILVUS_URI=http://192.168.0.x:19530   # 远程 Milvus Standalone 服务器
# MILVUS_TOKEN=root:your_password        # 鉴权 token（无鉴权留空）
# MILVUS_COLLECTION=kb_chunks            # collection 名称（默认 kb_chunks）
# MILVUS_VECTOR_SIZE=1536                # embedding 维度，需与模型一致
# MILVUS_INDEX_TYPE=HNSW                 # HNSW | DISKANN（>500万向量推荐 DISKANN）
#
# Qdrant 连接参数（VECTOR_BACKEND=qdrant 时生效）：
# QDRANT_PATH=./data/qdrant              # 嵌入式模式数据目录
# QDRANT_API_KEY=                        # 服务器模式鉴权 key
# QDRANT_VECTOR_SIZE=1536
#
# 敏感信息（token/password）建议写入此 .env 文件，
# llm.yaml 中通过 ${MILVUS_TOKEN} 语法引用，避免密钥明文提交到代码库。
MILVUS_TOKEN=
MILVUS_PASSWORD=123456

# ── vLLM / LM Studio API Key ──────────────────────────────
# llm.yaml 中 vllm-qwen3 引擎通过 ${VLLM_API_KEY} 引用
VLLM_API_KEY=sk-lm-O51vJwkZ:8YkCeVGAMnk28agmlS1V

# ── 编排模式 ──────────────────────────────────────────────
# react | plan_execute
ORCHESTRATOR_TYPE=react
MAX_STEPS=20
TOKEN_BUDGET=12000

# ── API 服务器 ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── 日志 ─────────────────────────────────────────────────
LOG_LEVEL=INFO
JSON_LOGS=false

# ── LLM 调用全链路日志 ────────────────────────────────────
# 记录每次 chat / stream_chat / embed 的请求参数、返回参数和异常
# 同时输出到控制台（structlog）和本地 JSONL 文件（RotatingFileHandler）
#
# 控制台输出：受 LOG_LEVEL 控制；将 LOG_LEVEL=DEBUG 可看到全部 request/response
# 文件输出：始终记录，不受 LOG_LEVEL 影响（独立 handler）
#
LLM_CALL_LOG_ENABLED=true
LLM_CALL_LOG_LEVEL=DEBUG            # 控制台打印级别（DEBUG=全量 | INFO=仅异常和慢请求）
LLM_CALL_LOG_FILE=logs/llm_calls.jsonl   # 设为空字符串可禁用文件写入
LLM_CALL_LOG_MAX_BYTES=10485760     # 单文件最大字节（默认 10 MB）
LLM_CALL_LOG_BACKUP_COUNT=5         # 保留的历史轮转文件数
LLM_CALL_LOG_MSG_PREVIEW=500        # 消息内容最多记录字符数（防止敏感信息过多写入）

# ══════════════════════════════════════════════════════════
# 快速切换示例：
#
# 用 Claude Haiku（更便宜）:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-haiku-4-5-20251001
#
# 用 DeepSeek:
#   LLM_PROVIDER=deepseek
#   DEEPSEEK_API_KEY=sk-...
#   LLM_MODEL=deepseek-chat
#
# 用本地 Ollama（推理 + Embedding 分离，推荐）：
#   推荐通过 llm.yaml 配置双引擎，见 llm.yaml 中 ollama-qwen3 + ollama-embed 示例
#
# 简单单引擎模式（embedding 退化为 hash 向量，RAG 仅 BM25 有效）：
#   LLM_PROVIDER=ollama
#   LLM_MODEL=qwen3.5:35b-a3b
#   LLM_BASE_URL=http://192.168.0.222:11434/v1
#   （无需 API Key，确保 ollama serve 正在运行）
#
# 启用 qwen3-embedding 完整语义检索：
#   1. ollama pull qwen3-embedding:8b
#   2. 在 llm.yaml 中取消注释 ollama-embed + embed: ollama-embed（已预配置）
#
# 用 Azure OpenAI:
#   LLM_PROVIDER=azure
#   AZURE_OPENAI_API_KEY=...
#   AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com
#   AZURE_OPENAI_DEPLOYMENT=my-deployment
# ══════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════
# 多模型路由配置（Multi-Model Router）
# 不配置 ROUTER_ENGINES 时退化为单引擎模式（向后兼容）
# ══════════════════════════════════════════════════════════

# 注册的引擎别名列表（逗号分隔，顺序即默认优先级）
# ROUTER_ENGINES=claude-smart,claude-fast,gpt-embed,deepseek

# 每个别名通过 <ALIAS>_PROVIDER / <ALIAS>_MODEL 等变量配置：
# CLAUDE_SMART_PROVIDER=anthropic
# CLAUDE_SMART_MODEL=claude-sonnet-4-20250514
# CLAUDE_SMART_API_KEY=sk-ant-...

# CLAUDE_FAST_PROVIDER=anthropic
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_FAST_API_KEY=sk-ant-...          # 可与 claude-smart 共用同一个 key

# GPT_EMBED_PROVIDER=openai
# GPT_EMBED_MODEL=text-embedding-3-small
# GPT_EMBED_API_KEY=sk-...
# GPT_EMBED_EMBED=true                    # 标记为 embed 专用引擎

# DEEPSEEK_PROVIDER=deepseek
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 任务路由映射 ──────────────────────────────────────────
# 每种任务类型指定使用哪个别名，留空则使用 ROUTER_ENGINES 第一个
# ROUTER_CHAT=claude-smart        # 主推理（ReAct 循环）
# ROUTER_PLAN=claude-smart        # Plan-Execute 规划阶段
# ROUTER_SUMMARIZE=claude-fast    # 文本摘要/上下文压缩
# ROUTER_CONSOLIDATE=claude-fast  # 记忆固化提炼
# ROUTER_EMBED=gpt-embed          # 向量化（RAG + 长期记忆）
# ROUTER_EVAL=claude-fast         # Eval LLM-as-judge 打分
# ROUTER_ROUTE=claude-fast        # Multi-Agent 路由决策
# ROUTER_FALLBACK=deepseek        # 所有任务的兜底链（逗号分隔）

# ── 典型配置示例 ──────────────────────────────────────────
#
# 场景 A：Anthropic 主推理 + 便宜模型做辅助任务
#   ROUTER_ENGINES=claude-smart,claude-fast
#   CLAUDE_SMART_PROVIDER=anthropic
#   CLAUDE_SMART_MODEL=claude-sonnet-4-20250514
#   CLAUDE_FAST_PROVIDER=anthropic
#   CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
#   ROUTER_CHAT=claude-smart
#   ROUTER_SUMMARIZE=claude-fast
#   ROUTER_CONSOLIDATE=claude-fast
#   ROUTER_EVAL=claude-fast
#
# 场景 B：主模型 + DeepSeek 兜底（节省成本）
#   ROUTER_ENGINES=claude-smart,deepseek
#   ROUTER_FALLBACK=deepseek
#
# 场景 C：不同供应商各司其职
#   ROUTER_ENGINES=claude-smart,gpt-embed,deepseek-fast
#   ROUTER_CHAT=claude-smart
#   ROUTER_EMBED=gpt-embed
#   ROUTER_SUMMARIZE=deepseek-fast
#   ROUTER_CONSOLIDATE=deepseek-fast
#   ROUTER_EVAL=deepseek-fast
#
# 场景 D：代码通过 AgentConfig 在节点级覆盖（无需改 .env）
#   config = AgentConfig(model_alias="deepseek-fast")  # 指定引擎
#   config = AgentConfig(node_id="expensive_step")     # 走 node_overrides 映射


# ── 智能报表（AgentBiSkill）────────────────────────────────
# BI 报表接口地址（默认 https://fnb-qrcode.neargo.ai/v1/report/agent_bi）
# AGENT_BI_API_URL=https://fnb-qrcode.neargo.ai/v1/report/agent_bi
# BI 接口鉴权 Token（可选，接口需要 Bearer Token 时设置）
# AGENT_BI_API_KEY=
# 默认门店ID（前端未输入时自动使用；留空则查询全部门店）
AGENT_BI_DEFAULT_BRA_ID=B17612377308779358
