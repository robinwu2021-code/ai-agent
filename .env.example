# ══════════════════════════════════════════════════════════
# AI Agent 环境配置
# 复制为 .env 并填写实际值
# ══════════════════════════════════════════════════════════

# ── LLM 提供商选择 ────────────────────────────────────────
# 可选值: anthropic | openai | azure | deepseek | groq | ollama | custom
LLM_PROVIDER=anthropic

# ── API Key ───────────────────────────────────────────────
# 通用 Key 字段（优先级最高）
# LLM_API_KEY=

# 提供商专用字段（当 LLM_API_KEY 未设置时自动读取）
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# AZURE_OPENAI_API_KEY=...

# ── API 端点 ──────────────────────────────────────────────
# 留空表示使用该提供商的默认端点
# LLM_BASE_URL=

# OpenAI 兼容接口示例：
# LLM_BASE_URL=https://api.deepseek.com/v1        # DeepSeek
# LLM_BASE_URL=https://api.groq.com/openai/v1     # Groq
# LLM_BASE_URL=http://localhost:11434/v1           # Ollama（本地）
# LLM_BASE_URL=https://your-resource.openai.azure.com  # Azure

# Azure 专用配置
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=my-gpt4o-deployment

# ── 模型选择 ──────────────────────────────────────────────
# 留空则使用各提供商的默认模型：
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4o
#   deepseek  → deepseek-chat
#   groq      → llama-3.3-70b-versatile
#   ollama    → llama3.2

# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MODEL=gpt-4o
# LLM_MODEL=deepseek-chat
# LLM_MODEL=qwen2.5:72b                  # Ollama 自定义模型

# Embedding 模型（留空则使用提供商默认，Anthropic 回退到哈希向量）
# LLM_EMBEDDING_MODEL=text-embedding-3-small

# 摘要专用模型（可用便宜模型，留空同 LLM_MODEL）
# LLM_SUMMARIZE_MODEL=claude-haiku-4-5-20251001
# LLM_SUMMARIZE_MODEL=gpt-4o-mini

# ── 请求参数 ──────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SEC=120.0
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.7

# HTTP 代理（可选，例如 http://127.0.0.1:7890）
# LLM_HTTP_PROXY=

# ── 存储后端 ──────────────────────────────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379

USE_QDRANT=false
QDRANT_URL=http://localhost:6333

# ── 编排模式 ──────────────────────────────────────────────
# react | plan_execute
ORCHESTRATOR_TYPE=react
MAX_STEPS=20
TOKEN_BUDGET=12000

# ── API 服务器 ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── 日志 ─────────────────────────────────────────────────
LOG_LEVEL=INFO
JSON_LOGS=false

# ══════════════════════════════════════════════════════════
# 快速切换示例：
#
# 用 Claude Haiku（更便宜）:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-haiku-4-5-20251001
#
# 用 DeepSeek:
#   LLM_PROVIDER=deepseek
#   DEEPSEEK_API_KEY=sk-...
#   LLM_MODEL=deepseek-chat
#
# 用本地 Ollama:
#   LLM_PROVIDER=ollama
#   LLM_MODEL=qwen2.5:7b
#   （无需 API Key，确保 ollama serve 正在运行）
#
# 用 Azure OpenAI:
#   LLM_PROVIDER=azure
#   AZURE_OPENAI_API_KEY=...
#   AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com
#   AZURE_OPENAI_DEPLOYMENT=my-deployment
# ══════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════
# 多模型路由配置（Multi-Model Router）
# 不配置 ROUTER_ENGINES 时退化为单引擎模式（向后兼容）
# ══════════════════════════════════════════════════════════

# 注册的引擎别名列表（逗号分隔，顺序即默认优先级）
# ROUTER_ENGINES=claude-smart,claude-fast,gpt-embed,deepseek

# 每个别名通过 <ALIAS>_PROVIDER / <ALIAS>_MODEL 等变量配置：
# CLAUDE_SMART_PROVIDER=anthropic
# CLAUDE_SMART_MODEL=claude-sonnet-4-20250514
# CLAUDE_SMART_API_KEY=sk-ant-...

# CLAUDE_FAST_PROVIDER=anthropic
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_FAST_API_KEY=sk-ant-...          # 可与 claude-smart 共用同一个 key

# GPT_EMBED_PROVIDER=openai
# GPT_EMBED_MODEL=text-embedding-3-small
# GPT_EMBED_API_KEY=sk-...
# GPT_EMBED_EMBED=true                    # 标记为 embed 专用引擎

# DEEPSEEK_PROVIDER=deepseek
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 任务路由映射 ──────────────────────────────────────────
# 每种任务类型指定使用哪个别名，留空则使用 ROUTER_ENGINES 第一个
# ROUTER_CHAT=claude-smart        # 主推理（ReAct 循环）
# ROUTER_PLAN=claude-smart        # Plan-Execute 规划阶段
# ROUTER_SUMMARIZE=claude-fast    # 文本摘要/上下文压缩
# ROUTER_CONSOLIDATE=claude-fast  # 记忆固化提炼
# ROUTER_EMBED=gpt-embed          # 向量化（RAG + 长期记忆）
# ROUTER_EVAL=claude-fast         # Eval LLM-as-judge 打分
# ROUTER_ROUTE=claude-fast        # Multi-Agent 路由决策
# ROUTER_FALLBACK=deepseek        # 所有任务的兜底链（逗号分隔）

# ── 典型配置示例 ──────────────────────────────────────────
#
# 场景 A：Anthropic 主推理 + 便宜模型做辅助任务
#   ROUTER_ENGINES=claude-smart,claude-fast
#   CLAUDE_SMART_PROVIDER=anthropic
#   CLAUDE_SMART_MODEL=claude-sonnet-4-20250514
#   CLAUDE_FAST_PROVIDER=anthropic
#   CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
#   ROUTER_CHAT=claude-smart
#   ROUTER_SUMMARIZE=claude-fast
#   ROUTER_CONSOLIDATE=claude-fast
#   ROUTER_EVAL=claude-fast
#
# 场景 B：主模型 + DeepSeek 兜底（节省成本）
#   ROUTER_ENGINES=claude-smart,deepseek
#   ROUTER_FALLBACK=deepseek
#
# 场景 C：不同供应商各司其职
#   ROUTER_ENGINES=claude-smart,gpt-embed,deepseek-fast
#   ROUTER_CHAT=claude-smart
#   ROUTER_EMBED=gpt-embed
#   ROUTER_SUMMARIZE=deepseek-fast
#   ROUTER_CONSOLIDATE=deepseek-fast
#   ROUTER_EVAL=deepseek-fast
#
# 场景 D：代码通过 AgentConfig 在节点级覆盖（无需改 .env）
#   config = AgentConfig(model_alias="deepseek-fast")  # 指定引擎
#   config = AgentConfig(node_id="expensive_step")     # 走 node_overrides 映射
